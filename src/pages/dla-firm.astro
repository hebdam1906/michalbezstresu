---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Stopka from '../components/Stopka.astro';

const warsztaty = [
  {
    tag: 'Dla menedżerów',
    t: 'Feedback, który nie niszczy',
    d: 'Jak dawać trudną informację zwrotną tak, żeby druga strona wyszła z rozmowy z planem, a nie z lękiem. Fakty zamiast ocen, konkret zamiast ogólników.',
    pkt: ['Struktura rozmowy feedbackowej', 'Język faktów kontra język etykiet', 'Trudne przypadki i eskalacje', 'Ćwiczenia na realnych scenariuszach'],
  },
  {
    tag: 'Dla zespołów',
    t: 'Zarządzanie stresem w zespole',
    d: 'Praktyczne narzędzia obniżania napięcia w pracy pod presją — bez coachingowych sloganów. Dla zespołów po reorganizacji, w intensywnym okresie lub po prostu zmęczonych.',
    pkt: ['Skąd bierze się stres organizacyjny', 'Higiena pracy i granice po godzinach', 'Komunikacja, która nie eskaluje', 'Nawyki zespołowe na trudne tygodnie'],
  },
  {
    tag: 'Dla organizacji',
    t: 'Profilaktyka antymobbingowa',
    d: 'Edukacyjny warsztat o granicach, dokumentowaniu i reagowaniu — budujący kulturę, w której trudne sytuacje wychodzą na jaw wcześnie, a nie po latach.',
    pkt: ['Gdzie kończy się wymagający szef', 'Rola świadka i osoby zgłaszającej', 'Dokumentowanie i ścieżki zgłoszeń', 'Element wsparcia obowiązków pracodawcy'],
  },
];
---
<Layout
  title="Szkolenia i warsztaty dla firm | Michał bez Stresu"
  description="Warsztaty prowadzone przez praktyka z 20-letnim doświadczeniem operacyjnym w korporacji: feedback, który nie niszczy, zarządzanie stresem w zespole, profilaktyka antymobbingowa."
>
  <Nav />

  <header class="phead">
    <div class="wrap">
      <div class="eyebrow">Dla firm</div>
      <h1>Szkolenia prowadzone przez praktyka,<br/>nie przez prezentację</h1>
      <p class="lead">Feedback, stres, trudne rozmowy, profilaktyka antymobbingowa —
        warsztaty oparte na 20 latach realnej pracy operacyjnej w korporacji, a nie na
        teorii z podręcznika. Konkretne narzędzia, które zespół zastosuje następnego dnia.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="mailto:kontakt@michalbezstresu.pl?subject=Szkolenie%20dla%20zespołu">Porozmawiajmy o Twoim zespole</a>
        <span class="cta-note">Odpowiadam osobiście, zwykle w ciągu jednego dnia roboczego.</span>
      </div>
    </div>
  </header>

  <section>
    <div class="wrap">
      <div class="eyebrow">Oferta</div>
      <h2>Trzy warsztaty, które robią różnicę</h2>
      <p class="sub">Każdy warsztat dopasowuję do realiów zespołu i branży. Poniżej wersje
        bazowe — zakres i długość ustalamy wspólnie.</p>
      <div class="cards">
        {warsztaty.map((w) => (
          <article class="card">
            <span class="tag">{w.tag}</span>
            <h3>{w.t}</h3>
            <p class="cd">{w.d}</p>
            <ul>
              {w.pkt.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band">
    <div class="wrap">
      <div class="eyebrow">Jak pracuję</div>
      <h2>Bez slajdowego teatru</h2>
      <div class="steps">
        <div class="step"><span class="snr">1</span><h3>Rozmowa i diagnoza</h3><p>Poznaję sytuację zespołu i realny problem. Nie sprzedaję gotowca, zanim nie zrozumiem kontekstu.</p></div>
        <div class="step"><span class="snr">2</span><h3>Warsztat na Waszych przykładach</h3><p>Pracujemy na scenariuszach z Waszej codzienności, nie na abstrakcyjnych case'ach. Więcej ćwiczeń niż wykładu.</p></div>
        <div class="step"><span class="snr">3</span><h3>Narzędzia do zabrania</h3><p>Uczestnicy wychodzą z konkretnymi szablonami i zdaniami do użycia od zaraz — nie z samą inspiracją.</p></div>
      </div>
    </div>
  </section>

  <section class="band author">
    <div class="wrap author-in">
      <div>
        <div class="eyebrow">Kto prowadzi</div>
        <h2>Michał — 20 lat w korporacji</h2>
        <p class="sub">Senior manager z doświadczeniem operacyjnym w dużych organizacjach,
          praktyk usprawniania procesów. Prowadziłem zespoły, oceny, plany naprawcze
          i trudne rozstania — dlatego wiem, jak te sytuacje wyglądają naprawdę, a nie
          tylko na slajdzie.</p>
        <a class="btn btn-ghost" href="/#omnie">Więcej o mnie</a>
      </div>
      <div class="badge">
        <span class="mono">notatka służbowa</span>
        <p>„Nie nauczę Waszych menedżerów mówić ładnych zdań.<br/>Nauczę ich prowadzić trudne
          rozmowy tak, żeby ludzie zostawali, a nie odchodzili.”</p>
      </div>
    </div>
  </section>

  <section class="closing">
    <div class="wrap">
      <h2>Opowiedz mi o swoim zespole</h2>
      <p class="sub">Napisz kilka zdań o sytuacji i tym, co chcecie zmienić. Wrócę z propozycją
        warsztatu dopasowaną do Waszych realiów i budżetu.</p>
      <a class="btn btn-primary" href="mailto:kontakt@michalbezstresu.pl?subject=Szkolenie%20dla%20zespołu">Napisz do mnie</a>
      <p class="mail-alt">albo bezpośrednio: <a href="mailto:kontakt@michalbezstresu.pl">kontakt@michalbezstresu.pl</a></p>
    </div>
  </section>

  <Stopka />
</Layout>

<style>
.phead{padding:72px 0 60px;background:linear-gradient(180deg,var(--mgla),var(--papier))}
.phead h1{font-family:var(--disp);font-weight:500;font-size:clamp(32px,5vw,54px);line-height:1.12;margin-bottom:18px}
.phead .lead{font-size:clamp(17px,2.2vw,20px);color:#3C4A46;max-width:62ch}
.cta-row{display:flex;align-items:center;gap:20px;flex-wrap:wrap;margin-top:32px}
.cta-note{font-size:14px;color:#5E6E68;max-width:32ch}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px}
@media(max-width:900px){.cards{grid-template-columns:1fr}}
.card{background:var(--papier);border:1px solid var(--linia);border-radius:12px;padding:28px 26px;display:flex;flex-direction:column}
.card .tag{font-family:var(--mono);font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;background:rgba(46,107,93,.12);color:var(--sygnal);padding:4px 10px;border-radius:99px;align-self:flex-start;margin-bottom:16px}
.card h3{font-size:22px;margin-bottom:10px}
.card .cd{font-size:15px;color:#4A5A55;margin-bottom:18px}
.card ul{list-style:none;margin-top:auto}
.card li{padding-left:24px;position:relative;font-size:14.5px;margin-bottom:9px;color:#3C4A46}
.card li::before{content:"→";position:absolute;left:0;color:var(--szalwia)}
.band{background:var(--papier);border-top:1px solid var(--linia);border-bottom:1px solid var(--linia)}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:40px}
@media(max-width:900px){.steps{grid-template-columns:1fr}}
.step .snr{display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;background:var(--marker);color:#6B5A14;font-family:var(--disp);font-size:20px;margin-bottom:14px}
.step h3{font-size:19px;margin-bottom:8px}
.step p{font-size:15px;color:#4A5A55}
.author-in{display:grid;grid-template-columns:1.15fr .85fr;gap:44px;align-items:center}
@media(max-width:820px){.author-in{grid-template-columns:1fr}}
.badge{background:var(--sygnal);color:#F2F7F5;border-radius:14px;padding:30px 28px}
.badge .mono{font-family:var(--mono);font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--marker);display:block;margin-bottom:14px}
.badge p{font-family:var(--disp);font-size:20px;line-height:1.45}
.closing{text-align:center}
.closing .sub{margin:0 auto 28px}
.closing h2{margin-bottom:14px}
.mail-alt{margin-top:18px;font-size:14px;color:#5E6E68}
.mail-alt a{color:var(--sygnal);text-decoration:none}
</style>

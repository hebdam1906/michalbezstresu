# Michał bez Stresu — zmienne środowiskowe (Etap 2)
# Skopiuj ten plik do `.env` (lokalnie) i ustaw te same wartości w Vercel:
#   Vercel → Project → Settings → Environment Variables
#
# Znajdziesz je w Supabase → Project Settings → API:
#   PUBLIC_SUPABASE_URL       = Project URL
#   PUBLIC_SUPABASE_ANON_KEY  = anon / public key (NIE service_role!)
#
# Dopóki oba są PUSTE, strona używa lokalnej listy src/data/odcinki.js (Etap 1).

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
